PORT=3006
NODE_ENV=development
SALT_ROUNDS=11
DATABASE_URL=postgresql://postgres:####@localhost:5432/postgres?schema=public

# JWT — access token (short-lived)
JWT_SECRET=
JWT_EXPIRES_IN=15m

# Refresh token — long-lived, stored hashed in DB
REFRESH_TOKEN_SECRET=
REFRESH_TOKEN_EXPIRES_IN=7d

# Cloudinary — doctor photo and user avatar uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
UPLOAD_MAX_BYTES=5242880

# Password reset — email delivery via Resend (https://resend.com)
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev
APP_URL=http://localhost:5173

# Optional
CORS_ORIGIN=http://localhost:5173
LOG_LEVEL=info
