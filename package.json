{
  "name": "mediconnect",
  "version": "1.0.0",
  "private": true,
  "description": "MediConnect — medical appointment booking monorepo (backend + frontend).",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@mediconnect/backend",
    "dev:backend": "npm run dev --workspace=@mediconnect/backend",
    "dev:frontend": "npm run dev --workspace=@mediconnect/frontend",
    "build": "npm run build --workspace=@mediconnect/frontend",
    "start": "npm run start --workspace=@mediconnect/backend",
    "test": "npm test --workspace=@mediconnect/backend",
    "test:backend": "npm test --workspace=@mediconnect/backend",
    "test:frontend": "npm test --workspace=@mediconnect/frontend"
  },
  "author": "Carlos Gonzalez <carlosngonzalez0@gmail.com>",
  "license": "MIT"
}
